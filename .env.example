# Database — PostgreSQL 16 + PostGIS
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/omaparchive

# Auth.js v5 — generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-32-plus-char-random-string

# Node environment
NODE_ENV=development

# Azure Blob Storage — leave unset to use local filesystem fallback in development
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
# AZURE_STORAGE_SAS_TOKEN=your-sas-token

# Redis — leave as default for local development
REDIS_URL=redis://localhost:6379
